# Ejemplo de variables de entorno para el backend
# Clave de API de Resend (obligatorio para envíos reales)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Dirección desde la que se enviarán los correos (debe pertenecer al dominio verificado en Resend)
MAIL_FROM=onboarding@tudominio.com

# Opcionales
BCRYPT_COST=12
JWT_SECRET=changeme
